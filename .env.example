# ─── World Cup 2026 Backend — Environment Configuration ──────────────────────
# Copy this file to .env and fill in real values for your environment.
# Never commit .env to version control — it contains secrets.

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # Set to false in production

# ── Database (Supabase PostgreSQL or local Postgres) ─────────────────────────
DATABASE_URL=postgresql+psycopg2://wc2026_user:wc2026_dev_password@localhost:5432/wc2026_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=30             # Default cache lifetime for list endpoints
LIVE_CACHE_TTL_SECONDS=10        # Shorter TTL for /live (changes most often)

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. In production, use your real domains.
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Auth ─────────────────────────────────────────────────────────────────────
# MUST be changed in production — use `openssl rand -hex 32` to generate.
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_this_is_a_dev_only_default_key
ACCESS_TOKEN_EXPIRE_MINUTES=1440 # 24 hours

# ── Football Data Provider (Step 3/4) ────────────────────────────────────────
# Set to "mock" (default), "api_football", "sportmonks", or "football_data_api"
FOOTBALL_DATA_PROVIDER=mock

# API-Football (https://www.api-football.com) — free tier available
API_FOOTBALL_KEY=

# SportMonks (https://www.sportmonks.com) — paid tiers only
SPORTMONKS_KEY=
